# 复制为 .env 并填入真实 key；.env 已在 .gitignore，勿提交
# Gemini API（主体检测、智能换行、直连文生图/图编）
# 直连 Google：不设 GOOGLE_GEMINI_BASE_URL，GEMINI_API_KEY=你的 Google API Key
# Packy API：GOOGLE_GEMINI_BASE_URL=https://www.packyapi.com，GEMINI_API_KEY=Packy 的 sk- 令牌（文档 https://docs.packyapi.com/）
# 命令行加 -packy / --packy 时也可单独设 PACKY_API_KEY，本次运行会改用 Packy 后端
# GEMINI_API_KEY=your_gemini_key
# GEMINI_API_KEY_ALT=your_backup_gemini_key
# GOOGLE_GEMINI_BASE_URL=https://www.packyapi.com
# PACKY_API_KEY=sk-your_packy_token
# GEMINI_MODEL=gemini-3.1-flash-image-preview
# GEMINI_VISION_MODEL=gemini-2.5-flash
# GEMINI_PROMPT_OPTIMIZER_MODEL=gemini-2.5-flash

# Anthropic Claude（主副标题→文生图描述 prompt-optimizer：generate_from_description --prompt-optimizer claude，或 run_full_with_custom_prompt --prompt-optimizer-claude）
# ANTHROPIC_API_KEY=sk-ant-api03-...
# CLAUDE_PROMPT_OPTIMIZER_MODEL=claude-3-5-sonnet-20241022
# 可选：兼容代理基址（须提供 /v1/messages）
# ANTHROPIC_API_BASE_URL=https://api.anthropic.com

# 并行 Packy7s（与 Packy 并行的另一组 key）
# 命令行加 -packy7s / --packy7s 时会改用此 key（需在你自己的 7s 控制台生成）
# PACKY7S_API_KEY=sk-your_packy7s_token
#
# 若令牌在控制台限制了「仅部分模型可访问」，请与列表一致，可减少一次 403：
# 例：仅允许 gemini-3.1-flash-image-preview 做图编时：
# GEMINI_MODEL=gemini-3.1-flash-image-preview
# 例：主体检测 Vision 仅允许 gemini-3-flash-preview 时（可选）：
# GEMINI_VISION_MODEL=gemini-3-flash-preview

# Packy3s（第三代 Packy 后端，命令行加 -packy3s）
# PACKY3S_API_KEY=sk-your_packy3s_token

# PackyGPT（通过 Packy 调用 GPT Image，命令行加 -packygpt）
# t2i: /v1/images/generations，i2i/编辑: /v1/images/edits（multipart，支持 mask 遮罩）
# 无比例限制（2026-06 实测 2:1~8:1 全通过），不支持 Vision（gpt-image-2 仅为生图模型）
# 长连接建议直连，代理可能中断 → 设 PACKYGPT_NO_PROXY=1
# 文档: https://docs.packyapi.com/docs/paint/GPTImage.html
# PACKYGPT_API_KEY=sk-your_packygpt_token

# MicuAPI（通过 micuapi.ai 调用 gpt-image-2，命令行加 -micugpt2）
# t2i: /v1/images/generations，i2i/vision: /v1/chat/completions（JSON base64）
# 支持 1:8 极端比例直出，API 直连 + CDN 下载走代理
# 文档: https://docs.micuapi.ai/new/external-compat
# MICUAPI_API_KEY=sk-your_micuapi_token

# MicuGemini（通过 micuapi.ai 调用 gemini-3-flash-preview-thinking，命令行加 -micugemini）
# 端点: /v1/chat/completions（OpenAI 兼容）和 /v1beta/models/gemini-3-flash-preview-thinking:generateContent（原生）
# MICUGEMINI_API_KEY=sk-your_micugemini_token

# MoxinGPT（通过 moxin.studio 调用 gpt-image-2，命令行加 -moxingpt）
# NewAPI channel 连接；端点: /v1/chat/completions（OpenAI 兼容）
# 模型: gpt-image-2；参数: prompt（必填）、size（默认 auto）、quality（默认 auto）
# MOXINGPT_API_KEY=sk-your_moxingpt_token
# MOXINGPT_BASE_URL=https://www.moxin.studio
# MOXINGPT_MODEL=[次]gpt-image-2,gpt-image-2-c  # 可选，逗号分隔多模型（最多3个），按序重试；默认 [次]gpt-image-2,gpt-image-2-c
# MOXINGPT_SIZE=auto
# MOXINGPT_QUALITY=auto
# MOXINGPT_NO_PROXY=1  # 建议直连

# MoxinGemini（通过 moxin.studio 调用 Gemini，命令行加 -moxingemini）
# 端点: /v1/chat/completions（OpenAI 兼容），支持生图+编辑+Vision
# 可与 --moxingpt 组合使用，此时生图走 gpt-image-2，编辑走 MoxinGemini chat/completions
# MOXINGEMINI_API_KEY=sk-your_moxingemini_token
# MOXINGEMINI_BASE_URL=https://www.moxin.studio  # 可选，默认此值
# MOXINGEMINI_MODEL=[特价次卡]gemini-3.1-pro-preview,[次]gemini-3-pro-image  # 可选，逗号分隔多模型（最多3个），按序重试；无 think 模型，避免返回文本而非图片

# XingchenGPT（通过 newapi.pro 调用 gpt-image-2，命令行加 -xingchengpt）
# OpenAI 兼容接口；端点: /v1/images/generations（文生图）和 /v1/chat/completions（多模态图编）
# 模型: gpt-image-2；参数: prompt（必填）、size（默认 auto）、quality（默认 auto）
# XINGCHENGGPT_API_KEY=sk-your_xingchengpt_token
# XINGCHENGGPT_BASE_URL=https://api.newapi.pro
# XINGCHENGGPT_MODEL=gpt-image-2
# XINGCHENGGPT_SIZE=auto
# XINGCHENGGPT_QUALITY=auto
# XINGCHENGGPT_NO_PROXY=1  # 建议直连

# XinchenGPT（通过 api.centos.hk 调用 gpt-image-2，命令行加 -xinchengpt）
# OpenAI 兼容接口；端点: /v1/images/generations（文生图）和 /v1/chat/completions（多模态图编）
# 模型: gpt-image-2；参数: prompt（必填）、size（默认 auto）、quality（默认 auto）
# XINCHENGPT_API_KEY=sk-your_xinchengpt_token
# XINCHENGPT_BASE_URL=https://api.centos.hk
# XINCHENGPT_MODEL=gpt-image-2
# XINCHENGPT_SIZE=auto
# XINCHENGPT_QUALITY=auto
# XINCHENGPT_NO_PROXY=1  # 建议直连

# XingchenGemini（通过 api.centos.hk 调用 gemini-3.1-flash-image-preview，命令行加 -xingchengemini）
# OpenAI 兼容接口；端点: /v1/chat/completions（多模态）和 Gemini native generateContent
# 模型: gemini-3.1-flash-image-preview；支持生图+编辑+Vision
# XINGCHENGEMINI_API_KEY=sk-your_xingchengemini_token
# XINGCHENGEMINI_BASE_URL=https://api.centos.hk
#
# XingchenGemini 多 Key 轮换（命令行加 -xingchengemini1 / -xingchengemini2 ...）
# 与 --xingchengemini 功能相同，使用独立 key，支持多账户轮换
# XINGCHENGEMINI1_API_KEY=sk-your_xingchengemini1_token
# XINGCHENGEMINI1_BASE_URL=https://api.centos.hk  # 可选，默认回退 XINGCHENGEMINI_BASE_URL

# 火山引擎即梦 4.0 直连（scripts/jimeng_volc_api.py 文生图/图生图）
# VOLC_ACCESS_KEY_ID=your_volc_access_key_id
# VOLC_SECRET_ACCESS_KEY=your_volc_secret_access_key

# 即梦 / t8star（文生图 --model t8-jimeng，图生图 BANNER_IMAGE_BACKEND=t8star）
# T8STAR_API_KEY=your_t8star_or_jimeng_key
# T8STAR_IMAGE_MODEL=jimeng
# BANNER_IMAGE_BACKEND=t8star
# T8STAR_BASE_URL=https://ai.t8star.cn

# Lovart AI（文生图/图生图/图编 BANNER_IMAGE_BACKEND=lovart）
# 获取密钥：https://www.lovart.ai（头像菜单 → AK/SK 管理）
# LOVART_ACCESS_KEY=ak_xxx
# LOVART_SECRET_KEY=sk_xxx
# LOVART_PROJECT_ID=          # 可选，指定专用项目 ID；不填则自动创建 banner-background 项目
# LOVART_PREFER_MODELS=generate_image_seedream_3_0,generate_image_nano_banana_pro
# LOVART_UNLIMITED_TIMEOUT=120   # unlimited 模式超时秒数，超时后自动切 fast 模式
# LOVART_FAST_TIMEOUT=600        # fast 模式超时秒数
# LOVART_INSECURE_SSL=           # 设为 1 时禁用 SSL 验证（仅开发/调试用）
# BANNER_IMAGE_BACKEND=lovart    # 启用 Lovart 后端

# bg.png 生图尺寸（run_full_with_custom_prompt.py 分组模式用）
# 不设时：packygpt/micugpt2 → 1024x640（gpt-image-2 原生），其他 → 1920x1080（16:9）
# BANNER_BG_SIZE=1024x640

# BiRefNet 抠图参数
# WIDE_A5B_ALPHA_THRESHOLD=0.4    # 0~1，专题长图 A5b 顶条抠图专用阈值；默认 0.5；越低边缘越软
# WIDE_A5B_MIN_COMPONENT_AREA=1200  # A5b 去装饰碎屑的连通域最小面积（像素），默认 3000；设 0 关闭过滤
# BIREFNET_ALPHA_THRESHOLD=0.7   # 0~1，extract_subject_birefnet.py 独立抠图脚本用；默认 0.7
# WIDE_A5B_NO_GEMINI_FALLBACK=   # 设为 1 时，BiRefNet 失败不再回退 Gemini，直接报错
